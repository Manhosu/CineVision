{
  "name": "cine-vision",
  "version": "1.0.0",
  "description": "Cine Vision - Netflix-like streaming platform with Telegram integration",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix bot\"",
    "build": "npm run build --prefix backend",
    "start": "npm run start:prod --prefix backend",
    "lint": "npm run lint --prefix backend",
    "test": "npm run test --prefix backend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix bot",
    "clean": "npm run clean --prefix backend",
    "docker:dev": "docker-compose up --build",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "streaming",
    "telegram",
    "movies",
    "netflix",
    "payments"
  ],
  "author": "Cine Vision Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@supabase/supabase-js": "^2.75.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "form-data": "^4.0.4"
  }
}
